# ------- تنظیمات سرور -------
PORT=4000
NODE_ENV=development

# آدرس فرانت‌اند (برای CORS و بازگشت بعد از پرداخت)
FRONTEND_URL=http://localhost:5173

# ------- دیتابیس -------
# برای MongoDB Atlas (ابری، رایگان) یا یک MongoDB محلی/روی سرور خودتان
MONGO_URI=mongodb://127.0.0.1:27017/nouvelle-gallery

# ------- احراز هویت -------
# یک رشته‌ی تصادفی و طولانی و محرمانه برای امضای توکن‌های JWT بگذارید
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXPIRES_IN=7d

# اطلاعات ورود مدیر پیش‌فرض (فقط برای اسکریپت seed استفاده می‌شود)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_FULLNAME=مدیر گالری نوول

# ------- درگاه پرداخت زرین‌پال -------
# مرچنت آیدی واقعی خود را از zarinpal.com دریافت کنید
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
# در حالت تست (sandbox) مقدار true بگذارید تا هیچ تراکنش واقعی انجام نشود
ZARINPAL_SANDBOX=true
# آدرسی که کاربر بعد از پرداخت به آن برمی‌گردد (باید در بک‌اند هندل شود)
ZARINPAL_CALLBACK_URL=http://localhost:4000/api/payment/verify

# قیمت پایه اولیه طلای ۱۸ عیار (تومان) - فقط برای seed اولیه
INITIAL_GOLD_PRICE=3850000
